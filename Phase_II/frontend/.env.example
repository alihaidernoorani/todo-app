# Better Auth Configuration
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-32-character-secret-here

# Local Development URLs
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Production URLs (for Vercel deployment)
# BETTER_AUTH_URL=https://todo-app-mu-two-48.vercel.app
# NEXT_PUBLIC_BETTER_AUTH_URL=https://todo-app-mu-two-48.vercel.app

# Database URL (PostgreSQL - Neon)
# Same database as backend for user/session storage
NEON_DATABASE_URL=postgresql://user:password@localhost:5432/todo_db

# Backend API URL
# IMPORTANT: Use BACKEND_URL for Server Actions (server-side only)
#            Use NEXT_PUBLIC_API_URL for Client Components (client-side)

# Server-side variable (required for Server Actions to work correctly)
BACKEND_URL=http://localhost:8000

# Client-side variable (for client components)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production (HuggingFace Space)
# BACKEND_URL=https://huggingface.co/spaces/alihaidernoorani/Todo_App
# NEXT_PUBLIC_API_URL=https://huggingface.co/spaces/alihaidernoorani/Todo_App

# Node Environment
NODE_ENV=development

# Optional: Enable debug logging
NEXT_PUBLIC_DEBUG=true

# ─── Social Login (OAuth) ─────────────────────────────────────────────────────
# Google OAuth2 credentials
# Setup: Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Callback URI to whitelist: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth credentials
# Setup: Facebook Developer Portal → My Apps → App Settings → Basic
# Callback URI to whitelist: ${BETTER_AUTH_URL}/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
# ─────────────────────────────────────────────────────────────────────────────
